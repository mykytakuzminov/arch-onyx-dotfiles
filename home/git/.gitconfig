[user]
  name = "Mykyta Kuzminov"
  email = "mykytakuzminov@gmail.com"

[init]
  defaultBranch = main

[core]
  editor = nvim

[color]
  ui = auto

[pull]
  rebase = true

[push]
  autoSetupRemote = true

[alias]
  st = status -sb
  cm = commit -m
  sw = switch
  br = branch
  lg = log --oneline --graph --decorate --all
  undo = reset --soft HEAD~1
  nuke = reset --hard HEAD~1
  unstage = restore --staged .
